# Local dev only: storefront API key (portal -> store -> API keys).
# Copy to .env.local. Do NOT set in production builds — there the store is
# resolved from the site's domain (Origin header).
VITE_STORE_KEY=

# Self-hosted builds only (GitHub Pages, your own CDN): where the Campfire
# Storefront API lives. Leave unset on *.campfirecommerce.com hosting, where
# the app calls same-origin /api/store.
# VITE_API_BASE_URL=https://campfirecommerce.com/api/store
